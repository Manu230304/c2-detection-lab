<Sysmon schemaversion="4.90">
  <!--
    Sysmon configuration used in this lab.
    Based on SwiftOnSecurity sysmon-config (https://github.com/SwiftOnSecurity/sysmon-config)
    Trimmed to the event types most relevant to C2 and persistence detection.
  -->
  <HashAlgorithms>MD5,SHA256,IMPHASH</HashAlgorithms>
  <CheckRevocation/>

  <EventFiltering>

    <!-- Event ID 1 — Process Creation -->
    <RuleGroup name="" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <!-- Exclude noisy but trusted system processes -->
        <Image condition="is">C:\Windows\System32\wbem\WmiPrvSE.exe</Image>
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- Event ID 3 — Network Connection -->
    <RuleGroup name="" groupRelation="or">
      <NetworkConnect onmatch="exclude">
        <!-- Exclude known-good destinations to reduce noise -->
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
        <DestinationPort condition="is">443</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!-- Event ID 11 — File Create -->
    <RuleGroup name="" groupRelation="or">
      <FileCreate onmatch="include">
        <!-- Monitor Downloads and suspicious system paths -->
        <TargetFilename condition="contains">\Downloads\</TargetFilename>
        <TargetFilename condition="contains">\Windows\Tracing\</TargetFilename>
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- Event ID 12 & 13 — Registry Events -->
    <RuleGroup name="" groupRelation="or">
      <RegistryEvent onmatch="include">
        <!-- Monitor persistence locations -->
        <TargetObject condition="contains">Software\Microsoft\Windows\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">Software\Microsoft\Windows\CurrentVersion\RunOnce</TargetObject>
        <TargetObject condition="contains">\CurrentVersion\Winlogon</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- Event ID 22 — DNS Query -->
    <RuleGroup name="" groupRelation="or">
      <DnsQuery onmatch="exclude">
        <!-- Exclude Microsoft telemetry to reduce noise -->
        <QueryName condition="end with">.microsoft.com</QueryName>
        <QueryName condition="end with">.windows.com</QueryName>
      </DnsQuery>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
